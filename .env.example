# Copy to .env.local or set these variables in the shell.
# Never commit real secrets.
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_AI_BASE_URL=https://llm.api.cloud.yandex.net/v1
NORLAB_LLM_PROVIDER=yandex
OPENMODEL_API_KEY=
OPENMODEL_BASE_URL=https://api.openmodel.ai/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
NORLAB_LLM_MODE=real
NORLAB_GENERATOR_MODEL=gpt-oss-120b
NORLAB_FAST_MODEL=gpt-oss-120b
NORLAB_CRITIC_MODEL=gpt-oss-120b
NORLAB_USE_RESPONSES_API=false
NORLAB_STRICT_LLM=true
NORLAB_TASK_BACKEND=background
NORLAB_CHAT_REQUEST_TIMEOUT_SECONDS=75
NORLAB_CHAT_ATTEMPTS=1
NORLAB_GENERATION_EVIDENCE_LIMIT=36
NORLAB_LLM_GENERATION_ATTEMPTS=1
NORLAB_LLM_REFILL_ATTEMPTS=0
NORLAB_MAX_REPAIR_CALLS_PER_ATTEMPT=0
NORLAB_DEFAULT_HYPOTHESIS_CANDIDATES=12
NORLAB_MIN_ACCEPTED_HYPOTHESES=1
NORLAB_LLM_BATCH_SIZE=12
NORLAB_CHAT_MAX_OUTPUT_TOKENS=7000
NORLAB_EMBEDDING_REINDEX_LIMIT=64
NORLAB_EMBEDDING_STAGE_TIMEOUT_SECONDS=30
NORLAB_VISION_ANALYZE_LIMIT=4
NORLAB_VISION_MODEL=qwen3.6-35b-a3b
NORLAB_VISION_REQUEST_TIMEOUT_SECONDS=120
NORLAB_VISION_MAX_ATTEMPTS=2
NORLAB_EMBEDDING_MODEL=yandex-embeddings
NORLAB_EMBEDDING_DIMENSIONS=256
NORLAB_EMBEDDING_REQUEST_TIMEOUT_SECONDS=30
# Portable local defaults: these work with a single uvicorn process.
NORLAB_STORAGE_BACKEND=local
NORLAB_ENABLE_REDIS=false
NORLAB_ENABLE_NEO4J=false
NORLAB_OBJECT_STORAGE=local

# Optional infrastructure profile. Uncomment together with the matching
# Postgres, Redis, Neo4j, MinIO and Celery services.
# NORLAB_STORAGE_BACKEND=postgres
# DATABASE_URL=postgresql+psycopg://norlab:norlab@localhost:55432/norlab
# NORLAB_TASK_BACKEND=celery
# CELERY_BROKER_URL=redis://localhost:56379/0
# CELERY_RESULT_BACKEND=redis://localhost:56379/0
# NORLAB_ENABLE_REDIS=true
# REDIS_URL=redis://localhost:56379/0
# NORLAB_ENABLE_NEO4J=true
# NEO4J_URI=bolt://localhost:57687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=norlabpassword
# NORLAB_OBJECT_STORAGE=s3
# S3_ENDPOINT_URL=http://localhost:59000
# S3_ACCESS_KEY_ID=norlab
# S3_SECRET_ACCESS_KEY=norlabpassword
# S3_BUCKET=norlab
